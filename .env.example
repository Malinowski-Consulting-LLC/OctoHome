# OctoHome environment variables
# Copy this file to .env.local for local development.
# On Vercel, set these in Project → Settings → Environment Variables.

# ── Auth ──────────────────────────────────────────────────────────────────────
# A random secret used to sign session cookies.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# The app requests these scopes at sign-in: repo, read:user, user:email, workflow
GITHUB_ID=your_github_oauth_app_client_id
GITHUB_SECRET=your_github_oauth_app_client_secret

# ── App URL ───────────────────────────────────────────────────────────────────
# The canonical URL of the deployed app.
# Local development: http://localhost:3000
# Production (Vercel): https://your-project.vercel.app  (or your custom domain)
# Optional for the web app itself. Required for Tauri desktop builds because the
# release binary embeds this URL at compile time.
APP_URL=http://localhost:3000

# ── Upstash Redis (required in production for mutating API routes) ─────────────
# Create a Redis database at https://upstash.com and copy the REST credentials.
# Local development can leave these unset; production should fail closed without them.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
